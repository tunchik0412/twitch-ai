# Copy this file to .env.hetzner before starting docker-compose.

# Public domain that points to your Hetzner server.
DOMAIN=twitchgeminiaichatbot.duckdns.org

# Twitch extension settings.
TWITCH_EXTENSION_SECRET=replace_with_base64_extension_secret
TWITCH_CLIENT_ID=replace_with_twitch_client_id

# Twitch bot settings.
TWITCH_TOKEN=oauth:replace_with_bot_token
TWITCH_CHANNEL=yourchannelname
GEMINI_API_KEY=replace_with_gemini_api_key
BOT_PREFIX=!
COOLDOWN_SECONDS=5

# Bot fetches config from EBS.
EBS_URL=https://twitchgeminiaichatbot.duckdns.org

# Optional Flask flag used by some scripts.
FLASK_DEBUG=false
docker ps
docker compose version